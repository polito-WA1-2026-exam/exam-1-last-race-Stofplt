@baseUrl = http://localhost:3001/api

### Public - health
GET {{baseUrl}}/health

### Public - instructions
GET {{baseUrl}}/instructions

### Public - missing API route, expected 404
GET {{baseUrl}}/missing


### Auth - login Alice
# @name loginAlice
POST {{baseUrl}}/sessions
Content-Type: application/json

{
  "username": "alice@example.com",
  "password": "race-pass-1"
}

### Auth - current user
GET {{baseUrl}}/sessions/current
Cookie: {{loginAlice.response.headers.Set-Cookie}}

### Auth - bad login, expected 401
POST {{baseUrl}}/sessions
Content-Type: application/json

{
  "username": "alice@example.com",
  "password": "wrong-password"
}


### Setup - full network
# @name fullNetwork
GET {{baseUrl}}/network/full
Cookie: {{loginAlice.response.headers.Set-Cookie}}

### Setup - ranking without login, expected 401
GET {{baseUrl}}/ranking


### Game - start after network
# @name startGame
POST {{baseUrl}}/games
Cookie: {{loginAlice.response.headers.Set-Cookie}}

### Game - planning data
GET {{baseUrl}}/games/{{startGame.response.body.gameId}}/planning
Cookie: {{loginAlice.response.headers.Set-Cookie}}

### Game - submit empty route, expected valid=false score=0
POST {{baseUrl}}/games/{{startGame.response.body.gameId}}/route
Cookie: {{loginAlice.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "segments": []
}

### Game - result after failed route
GET {{baseUrl}}/games/{{startGame.response.body.gameId}}/result
Cookie: {{loginAlice.response.headers.Set-Cookie}}


### Game - start a second game for manual valid route testing
# @name startValidGame
POST {{baseUrl}}/games
Cookie: {{loginAlice.response.headers.Set-Cookie}}

### Game - submit manual route
# Manual helper: replace these ids with a valid route from startValidGame.startStation
# to startValidGame.destinationStation. The sample ids below are not expected to work
# for every random game.
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/route
Cookie: {{loginAlice.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "segments": [1, 3, 5]
}

### Game - execute next step
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginAlice.response.headers.Set-Cookie}}

### Game - result
GET {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/result
Cookie: {{loginAlice.response.headers.Set-Cookie}}

### Ranking - global best scores
GET {{baseUrl}}/ranking
Cookie: {{loginAlice.response.headers.Set-Cookie}}


### Error case - login Bruno without loading network
# @name loginBrunoNoNetwork
POST {{baseUrl}}/sessions
Content-Type: application/json

{
  "username": "bruno@example.com",
  "password": "race-pass-2"
}

### Error case - start game without network, expected 409
POST {{baseUrl}}/games
Cookie: {{loginBrunoNoNetwork.response.headers.Set-Cookie}}

### Error case - invalid game id, expected 422 after login
GET {{baseUrl}}/games/not-a-number/result
Cookie: {{loginAlice.response.headers.Set-Cookie}}


### Auth - logout Alice
DELETE {{baseUrl}}/sessions/current
Cookie: {{loginAlice.response.headers.Set-Cookie}}
