@baseUrl = http://localhost:3001/api

### Public - health
GET {{baseUrl}}/health

### Public - instructions
GET {{baseUrl}}/instructions

### Public - missing API route, expected 404
GET {{baseUrl}}/missing


### Auth - login Ulisse
# @name loginUlisse
POST {{baseUrl}}/sessions
Content-Type: application/json

{
  "username": "ulisse@lastrace.test",
  "password": "race-pass-1"
}

### Auth - current user
GET {{baseUrl}}/sessions/current
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Auth - bad login, expected 401
POST {{baseUrl}}/sessions
Content-Type: application/json

{
  "username": "ulisse@lastrace.test",
  "password": "wrong-password"
}


### Setup - full network
# Loads the setup map and enables game creation in the current session.
# @name fullNetwork
GET {{baseUrl}}/network/full
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Network - planning reduced payload
# Expected: stations + 23 bidirectional segment pairs, no line names and no SVG paths.
GET {{baseUrl}}/network/planning
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Network - station-only payload
# Expected: only station id/name/x/y data for the planning map.
GET {{baseUrl}}/network/stations
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Network - execution payload
# Expected: stations, lines and pathless segments. Route paths arrive only from execution state/next.
GET {{baseUrl}}/network/execution
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Setup - ranking without login, expected 401
GET {{baseUrl}}/ranking


### Game - start after network
# @name startGame
POST {{baseUrl}}/games
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Game - planning data
GET {{baseUrl}}/games/{{startGame.response.body.gameId}}/planning
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Game - submit empty route, expected valid=false score=0
POST {{baseUrl}}/games/{{startGame.response.body.gameId}}/route
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "segments": []
}

### Game - result after failed route
GET {{baseUrl}}/games/{{startGame.response.body.gameId}}/result
Cookie: {{loginUlisse.response.headers.Set-Cookie}}


### Game - start a second game for manual valid route testing
# @name startValidGame
POST {{baseUrl}}/games
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Game - planning data for valid game
GET {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/planning
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Game - submit sample fixed route
# Only valid if DEBUG_FIXED_ROUTE is temporarily set to true in server/gameLogic.js:
# Shady Grove -> Bethesda -> Metro Center -> Foggy Bottom -> L'Enfant Plaza -> Navy Yard -> Waterfront.
# @name submitValidRoute
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/route
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "segments": [1, 3, 17, 19, 21, 23]
}

### Game - duplicate route submit after accepted route, expected 409
# Covers the server-side status guard used against double submit/racing route requests.
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/route
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "segments": [1, 3, 17, 19, 21, 23]
}

### Game - execution state before first step
# Expected: coins=20, lastEvent=null, steps=[].
GET {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execution
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Game - execute next step
# Expected: one event, updated coins and exactly one segment path.
# @name executeStep1
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "expectedStepIndex": 1
}

### Game - duplicate first next request, expected 409 after executeStep1
# Covers racing/double-clicked Next calls with the same expected step index.
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "expectedStepIndex": 1
}

### Game - execution state after one step
# Expected: one executed step; refreshing the execution page can rebuild this state.
GET {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execution
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Game - execute remaining fixed-route steps
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "expectedStepIndex": 2
}

### Game - execute remaining fixed-route steps
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "expectedStepIndex": 3
}

### Game - execute remaining fixed-route steps
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "expectedStepIndex": 4
}

### Game - execute remaining fixed-route steps
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "expectedStepIndex": 5
}

### Game - execute final fixed-route step, expected completed=true
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "expectedStepIndex": 6
}

### Game - execute after completion, expected 409
# Covers duplicate/racing next-step calls after the route has no pending steps.
POST {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/execute/next
Cookie: {{loginUlisse.response.headers.Set-Cookie}}
Content-Type: application/json

{
  "expectedStepIndex": 7
}

### Game - result
GET {{baseUrl}}/games/{{startValidGame.response.body.gameId}}/result
Cookie: {{loginUlisse.response.headers.Set-Cookie}}

### Ranking - global best scores
GET {{baseUrl}}/ranking
Cookie: {{loginUlisse.response.headers.Set-Cookie}}


